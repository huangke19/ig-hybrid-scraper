#!/bin/bash
# Web UI 启停脚本
# 用法：
#   ./web         启动（后台）
#   ./web stop    优雅停止
#   ./web restart 重启

set -e

cd "$(dirname "$0")"

PID_FILE="gunicorn.pid"
LOG_FILE="web.log"
BOT_PID_FILE="telegram_bot.pid"
BOT_LOG_FILE="telegram_bot.log"

if [ -d ".venv" ]; then
    source .venv/bin/activate
fi

is_running() {
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE")
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

is_bot_running() {
    if [ -f "$BOT_PID_FILE" ]; then
        pid=$(cat "$BOT_PID_FILE")
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

start_server() {
    if is_running; then
        echo "⚠️  Web UI 已在运行（PID: $(cat "$PID_FILE")）"
        return 0
    fi

    echo "🚀 启动 IG 爬虫 Web UI（后台）..."
    echo "📱 手机访问: http://192.168.5.31:5000"
    echo "🌐 本地访问: http://localhost:5000"

    gunicorn -w 1 --threads 4 -b 0.0.0.0:5000 --timeout 120 --pid "$PID_FILE" --daemon --access-logfile "$LOG_FILE" --error-logfile "$LOG_FILE" web_app:app

    sleep 1
    if is_running; then
        echo "✅ Web UI 启动成功（PID: $(cat "$PID_FILE")）"
    else
        echo "❌ 启动失败，请查看日志：$LOG_FILE"
        exit 1
    fi

    if is_bot_running; then
        echo "⚠️  Telegram Bot 已在运行（PID: $(cat "$BOT_PID_FILE")）"
    else
        echo "🤖 启动 Telegram Bot（后台）..."
        nohup python telegram_command_bot.py > "$BOT_LOG_FILE" 2>&1 &
        echo $! > "$BOT_PID_FILE"
        sleep 1
        if is_bot_running; then
            echo "✅ Telegram Bot 启动成功（PID: $(cat "$BOT_PID_FILE")）"
        else
            echo "⚠️  Telegram Bot 启动失败，请查看日志：$BOT_LOG_FILE"
        fi
    fi
}

stop_server() {
    if ! is_running; then
        echo "ℹ️  Web UI 未在运行"
        [ -f "$PID_FILE" ] && rm -f "$PID_FILE"
    else
        pid=$(cat "$PID_FILE")
        echo "🛑 正在优雅停止 Web UI（PID: $pid）..."
        kill -TERM "$pid"

        for _ in {1..20}; do
            if kill -0 "$pid" 2>/dev/null; then
                sleep 0.2
            else
                break
            fi
        done

        if kill -0 "$pid" 2>/dev/null; then
            echo "⚠️  优雅停止超时，执行强制停止"
            kill -KILL "$pid" 2>/dev/null || true
        fi

        rm -f "$PID_FILE"
        echo "✅ Web UI 已停止"
    fi

    if is_bot_running; then
        pid=$(cat "$BOT_PID_FILE")
        echo "🛑 正在停止 Telegram Bot（PID: $pid）..."
        kill -TERM "$pid" 2>/dev/null || true
        sleep 1
        if kill -0 "$pid" 2>/dev/null; then
            kill -KILL "$pid" 2>/dev/null || true
        fi
        rm -f "$BOT_PID_FILE"
        echo "✅ Telegram Bot 已停止"
    fi
}

case "$1" in
    stop)
        stop_server
        ;;
    restart)
        stop_server
        start_server
        ;;
    *)
        start_server
        ;;
esac
