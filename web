#!/bin/bash
# 启动 Web UI 服务

cd "$(dirname "$0")"

# 激活虚拟环境（如果存在）
if [ -d ".venv" ]; then
    source .venv/bin/activate
fi

echo "🚀 启动 IG 爬虫 Web UI..."
echo "📱 手机访问: http://192.168.5.31:5000"
echo "🌐 本地访问: http://localhost:5000"
echo ""

# 使用 gunicorn 启动（单工作进程，避免 Socket.IO session 冲突）
gunicorn -w 1 -b 0.0.0.0:5000 --timeout 120 web_app:app
