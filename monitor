#!/bin/bash

# IG 监控脚本启动器
# 使用方法：./monitor

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# 激活虚拟环境
if [ -d ".venv" ]; then
    source .venv/bin/activate
elif [ -d "venv" ]; then
    source venv/bin/activate
else
    echo "⚠️  未找到虚拟环境，使用系统 Python"
fi

# 运行监控脚本
python3 monitor.py

# 退出时的状态码
exit $?
